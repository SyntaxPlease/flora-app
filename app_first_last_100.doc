1979: // â”€â”€â”€ ROOT APP â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
1980: export default function App() {
1981:   const [screen, setScreen] = useState("auth");
1982:   const [user, setUser] = useState(null);
1983:   const [answers, setAnswers] = useState({});
1984: 
1985:   const handleLogin = (u, goToDashboard=false) => { setUser(u); setScreen(goToDashboard?"dashboard":"quiz"); };
1986:   const handleQuizDone = async (ans) => {
1987:     setAnswers(ans);
1988: 
1989:     try {
1990:       await apiFetch("/api/assess", {
1991:         method:"POST",
1992:         body:JSON.stringify({ user_id:user?.id, answers:ans })
1993:       });
1994:     } catch (error) {
1995:       console.error("Could not save assessment", error);
1996:     }
1997: 
1998:     setScreen("dashboard");
1999:   };
2000:   const handleRetake = () => setScreen("quiz");
2001: 
2002:   return (
2003:     <>
2004:       <style>{css}</style>
2005:       {screen==="auth"      && <AuthScreen onLogin={handleLogin} />}
2006:       {screen==="quiz"      && <QuizScreen user={user} onComplete={handleQuizDone} />}
2007:       {screen==="dashboard" && <Dashboard user={user} answers={answers} onRetake={handleRetake} />}
2008:     </>
2009:   );
2010: }
