  33: const css = `
  34: @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap');
  35: *{box-sizing:border-box;margin:0;padding:0}
  36: body{background:${C.bg};font-family:${C.sans}}
  37: @keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
  38: @keyframes fadeIn{from{opacity:0}to{opacity:1}}
  39: @keyframes slideIn{from{opacity:0;transform:translateX(30px)}to{opacity:1;transform:translateX(0)}}
  40: @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
  41: @keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(74,222,128,0.3)}50%{box-shadow:0 0 0 12px rgba(74,222,128,0)}}
  42: @keyframes grow{from{transform:scaleX(0)}to{transform:scaleX(1)}}
  43: @keyframes typing{0%,60%,100%{opacity:1}30%{opacity:0.3}}
  44: @keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
  45: .fadeUp{animation:fadeUp 0.6s ease both}
  46: .fadeIn{animation:fadeIn 0.4s ease both}
  47: .slideIn{animation:slideIn 0.35s ease both}
  48: .float{animation:float 4s ease-in-out infinite}
  49: input,textarea{outline:none}
  50: input::placeholder,textarea::placeholder{color:${C.muted}}
  51: ::-webkit-scrollbar{width:4px}
  52: ::-webkit-scrollbar-track{background:transparent}
  53: ::-webkit-scrollbar-thumb{background:${C.dim};border-radius:4px}
  54: .bar-grow{animation:grow 1s cubic-bezier(0.34,1.56,0.64,1) both}
  55: .metric-card{cursor:pointer;transition:all 0.22s cubic-bezier(0.34,1.56,0.64,1)}
  56: .metric-card:hover{transform:translateY(-4px) scale(1.01);border-color:rgba(74,222,128,0.3)!important}
  57: .metric-card:active{transform:scale(0.97)}
  58: .image-card{transition:transform 0.24s cubic-bezier(0.34,1.56,0.64,1), border-color 0.24s ease, box-shadow 0.24s ease}
  59: .image-card:hover{transform:translateY(-4px);box-shadow:0 18px 36px rgba(0,0,0,0.18)}
  60: .image-card-media img{transition:transform 0.35s ease, filter 0.35s ease}
  61: .image-card:hover .image-card-media img{transform:scale(1.06);filter:saturate(1.08)}
  62: .feature-tile{position:relative;overflow:hidden}
  63: .feature-thumb{margin-top:12px;height:74px;border-radius:14px;overflow:hidden;border:1px solid rgba(255,255,255,0.06);background:rgba(255,255,255,0.03)}
  64: .feature-thumb img{width:100%;height:100%;object-fit:cover;display:block;transition:transform 0.35s ease, filter 0.35s ease}
  65: .feature-tile:hover .feature-thumb img{transform:scale(1.08);filter:saturate(1.1)}
  66: `;
