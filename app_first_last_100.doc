  68: const API_BASE = process.env.REACT_APP_API_URL || "http://localhost:8000";
  69: 
  70: async function apiFetch(path, options = {}) {
  71:   const response = await fetch(`${API_BASE}${path}`, {
  72:     ...options,
  73:     headers: {
  74:       "Content-Type": "application/json",
  75:       ...(options.headers || {}),
  76:     },
  77:   });
  78: 
  79:   const isJson = response.headers.get("content-type")?.includes("application/json");
  80:   const data = isJson ? await response.json() : null;
  81: 
  82:   if (!response.ok) {
  83:     throw new Error(data?.detail || "Request failed");
  84:   }
  85: 
  86:   return data;
  87: }
